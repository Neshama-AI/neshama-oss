# Neshama Model Adapter - Configuration Example
# 复制此文件为 config.yaml 并填入你的配置

version: "1.0.0"

# 默认模型
default_model: "gpt-4o"

# ===== Tier 1: 低价/试用优先 =====
providers:
  # 阿里云百炼 (通义千问)
  # 官网: https://dashscope.console.aliyun.com/
  dashscope:
    enabled: true
    api_key: "${DASHSCOPE_API_KEY}"
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    timeout: 60
    retry_times: 3
    models:
      - name: "qwen-plus"
        model_id: "qwen-plus"
        max_tokens: 8192
        temperature: 0.7
        priority: 10
      - name: "qwen-turbo"
        model_id: "qwen-turbo"
        max_tokens: 8192
        temperature: 0.7
        priority: 5
      - name: "qwen-max"
        model_id: "qwen-max"
        max_tokens: 8192
        temperature: 0.7
        priority: 20

  # 火山引擎方舟 (豆包)
  # 官网: https://console.volcengine.com/ark
  volcengine:
    enabled: true
    api_key: "${VOLCENGINE_API_KEY}"
    base_url: "https://ark.cn-beijing.volces.com/api/v3"
    timeout: 60
    retry_times: 3
    models:
      - name: "doubao-pro-32k"
        model_id: "doubao-pro-32k"
        max_tokens: 32768
        temperature: 0.7
        priority: 10

  # 百度千帆 (文心一言)
  # 官网: https://console.bce.baidu.com/qianfan/
  qianfan:
    enabled: true
    api_key: "${QIANFAN_ACCESS_KEY}"
    secret_key: "${QIANFAN_SECRET_KEY}"
    base_url: "https://qianfan.baidubce.com/v2"
    timeout: 60
    retry_times: 3
    models:
      - name: "ernie-4.0-8k"
        model_id: "ernie-4.0-8k-latest"
        max_tokens: 8192
        temperature: 0.7
        priority: 15
      - name: "ernie-speed-128k"
        model_id: "ernie-speed-128k"
        max_tokens: 128000
        temperature: 0.7
        priority: 5

# ===== Tier 2: 月费稳定 =====
  # MiniMax
  # 官网: https://www.minimaxi.com/
  minimax:
    enabled: true
    api_key: "${MINIMAX_API_KEY}"
    base_url: "https://api.minimax.chat/v1"
    timeout: 60
    retry_times: 3
    models:
      - name: "abab6-chat"
        model_id: "abab6.5s-chat"
        max_tokens: 16384
        temperature: 0.7
        priority: 10

  # 智谱GLM
  # 官网: https://open.bigmodel.cn/
  zhipu:
    enabled: true
    api_key: "${ZHIPU_API_KEY}"
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    timeout: 60
    retry_times: 3
    models:
      - name: "glm-4"
        model_id: "glm-4"
        max_tokens: 128000
        temperature: 0.7
        priority: 10
      - name: "glm-4-flash"
        model_id: "glm-4-flash"
        max_tokens: 128000
        temperature: 0.7
        priority: 5

# ===== Tier 3: Coding 类 =====
coding:
  # Cursor
  # 官网: https://cursor.com/
  cursor:
    enabled: false  # 需要单独申请
    api_key: "${CURSOR_API_KEY}"
    base_url: "https://api.cursor.com/v1"
    timeout: 60
    retry_times: 3
    models:
      - name: "cursor-small"
        model_id: "cursor-small"
        max_tokens: 4096
        temperature: 0.3
        priority: 10

  # GitHub Copilot
  # 官网: https://github.com/features/copilot
  copilot:
    enabled: false  # 需要 GitHub 账号
    api_key: "${GITHUB_TOKEN}"
    base_url: "https://api.githubcopilot.com"
    timeout: 60
    retry_times: 3
    models:
      - name: "copilot-gpt-4"
        model_id: "gpt-4"
        max_tokens: 4096
        temperature: 0.3
        priority: 10

# ===== Tier 4: 主流大模型 =====
  # OpenAI
  # 官网: https://platform.openai.com/
  openai:
    enabled: true
    api_key: "${OPENAI_API_KEY}"
    base_url: "https://api.openai.com/v1"
    timeout: 120
    retry_times: 3
    models:
      - name: "gpt-4o"
        model_id: "gpt-4o"
        max_tokens: 128000
        temperature: 0.7
        priority: 50
      - name: "gpt-4-turbo"
        model_id: "gpt-4-turbo"
        max_tokens: 128000
        temperature: 0.7
        priority: 40
      - name: "gpt-3.5-turbo"
        model_id: "gpt-3.5-turbo"
        max_tokens: 16385
        temperature: 0.7
        priority: 20

  # Anthropic (Claude)
  # 官网: https://www.anthropic.com/
  anthropic:
    enabled: true
    api_key: "${ANTHROPIC_API_KEY}"
    base_url: "https://api.anthropic.com/v1"
    timeout: 120
    retry_times: 3
    models:
      - name: "claude-3-5-sonnet"
        model_id: "claude-3-5-sonnet-20241022"
        max_tokens: 200000
        temperature: 0.7
        priority: 50
      - name: "claude-3-opus"
        model_id: "claude-3-opus-20240229"
        max_tokens: 200000
        temperature: 0.7
        priority: 60
      - name: "claude-3-haiku"
        model_id: "claude-3-haiku-20240307"
        max_tokens: 200000
        temperature: 0.7
        priority: 30

  # Google Gemini
  # 官网: https://ai.google.dev/
  gemini:
    enabled: true
    api_key: "${GEMINI_API_KEY}"
    base_url: "https://generativelanguage.googleapis.com/v1beta"
    timeout: 120
    retry_times: 3
    models:
      - name: "gemini-1.5-pro"
        model_id: "gemini-1.5-pro"
        max_tokens: 128000
        temperature: 0.7
        priority: 50
      - name: "gemini-1.5-flash"
        model_id: "gemini-1.5-flash"
        max_tokens: 128000
        temperature: 0.7
        priority: 30

  # Kimi (月之暗面)
  # 官网: https://platform.moonshot.cn/
  kimi:
    enabled: true
    api_key: "${KIMI_API_KEY}"
    base_url: "https://api.moonshot.cn/v1"
    timeout: 120
    retry_times: 3
    models:
      - name: "kimi-pro"
        model_id: "moonshot-v1-128k"
        max_tokens: 128000
        temperature: 0.7
        priority: 40
      - name: "kimi-flash"
        model_id: "moonshot-v1-8k"
        max_tokens: 8000
        temperature: 0.7
        priority: 20

  # 讯飞星火
  # 官网: https://www.xfyun.cn/
  xinghuo:
    enabled: true
    api_key: "${XINGHUO_API_KEY}"
    base_url: "https://spark-api.xf-yun.com"
    timeout: 60
    retry_times: 3
    models:
      - name: "spark-4.0"
        model_id: "generalv4.0"
        max_tokens: 8192
        temperature: 0.5
        priority: 30
      - name: "spark-3.5"
        model_id: "generalv3.5"
        max_tokens: 8192
        temperature: 0.5
        priority: 20

# ===== 路由器配置 =====
router:
  # 路由策略: priority | round_robin | weighted | failover | random
  strategy: "priority"
  
  # 是否启用故障转移
  failover_enabled: true
  
  # 健康检查间隔 (秒)
  health_check_interval: 60
  
  # 最大连续失败次数
  max_consecutive_failures: 3
